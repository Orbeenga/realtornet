# REALTORNET ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- DATABASE CONFIGURATION ---
POSTGRES_SERVER=aws-0-us-west-1.pooler.supabase.com
POSTGRES_USER=postgres.YOUR_PROJECT_ID
POSTGRES_PASSWORD=your-database-password
POSTGRES_DB=postgres
POSTGRES_PORT=6543

# Primary connection URL — Supabase pooler (IPv4-compatible)
# Username format: postgres.PROJECT_ID (required for pooler)
DATABASE_URL=postgresql+psycopg://postgres.YOUR_PROJECT_ID:your-password@aws-0-us-west-1.pooler.supabase.com:6543/postgres?sslmode=require

# Direct URL — same as DATABASE_URL for this setup
DIRECT_URL=postgresql+psycopg://postgres.YOUR_PROJECT_ID:your-password@aws-0-us-west-1.pooler.supabase.com:6543/postgres?sslmode=require

# Test database
TEST_POSTGRES_DB=postgres

# --- REDIS CONFIGURATION ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CELERY_BROKER=redis://localhost:6379/1
REDIS_CELERY_BACKEND=redis://localhost:6379/2

# --- SECURITY & API ---
# CORS origins — JSON array, comma-separated quoted strings
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Environment: development | staging | production
ENV=development
API_V1_STR=/api/v1

# SECRET_KEY — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be 64+ hex characters for production
SECRET_KEY=your-secret-key-min-64-chars
SENTRY_DSN=
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- SYSTEM SETTINGS ---
PYTHONPATH=.

# --- SUPABASE ---
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- EMAIL CONFIGURATION ---
# SMTP (optional for development)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM="RealtorNet <noreply@yourdomain.com>"

# Mailgun (production)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-domain.com
MAIL_FROM="RealtorNet <no-reply@your-domain.com>"
